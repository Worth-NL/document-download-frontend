{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generate DD-Frontend version file",
            "type": "shell",
            "command": "make generate-version-file",
            "problemMatcher": []
        },
        {
            "label": "Install DD-Frontend Python requirements",
            "type": "shell",
            "command": "uv pip install -r requirements_nl_test.txt",
            "dependsOn": ["Generate DD-Frontend version file"],
            "presentation": {
                "showReuseMessage": false,
                "close": true
            },
            "problemMatcher": [],
            "options": {
                "env": {
                    "UV_LINK_MODE": "copy"
                }
            }
        },
        {
            "label": "Install DD-Frontend local notifynl-utils",
            "type": "shell",
            "command": "uv pip uninstall notifynl-utils && uv pip install -e ../notifynl-utils",
            "dependsOn": ["Install DD-Frontend Python requirements"],
            "presentation": {
                "showReuseMessage": false,
                "close": true
            },
            "problemMatcher": [],
            "options": {
                "env": {
                    "UV_LINK_MODE": "copy"
                }
            }
        },
        {
            "label": "Install DD-Frontend local LandRegistry-frontend-jinja",
            "type": "shell",
            "command": "uv pip uninstall govuk-frontend-jinja && uv pip install -e ../LandRegistry-frontend-jinja",
            "dependsOn": ["Install DD-Frontend local notifynl-utils"],
            "presentation": {
                "showReuseMessage": false,
                "close": true
            },
            "problemMatcher": [],
            "options": {
                "env": {
                    "UV_LINK_MODE": "copy"
                }
            }
        },
        {
            "label": "NPM DD-Frontend install",
            "type": "shell",
            "command": "npm ci",
            "problemMatcher": [],
            "presentation": {
                "showReuseMessage": false,
                "close": true
            }
        },
        {
            "label": "NPM DD-Frontend build",
            "type": "shell",
            "command": "npm run build",
            "dependsOn": ["NPM DD-Frontend install"],
            "problemMatcher": [],
            "presentation": {
                "showReuseMessage": false,
                "close": true
            }
        }
    ]
}
